<!--
  TRMNL Solar System Viewer — Quadrant Layout
-->
<div class="layout layout--col gap--space-between">
  <div class="columns">
    <div class="column">
      <span class="title title--small">Planets</span>
    </div>
  </div>
  <div class="columns">
    <div class="column">
      {% for planet in planets %}
      {% if forloop.index <= 4 %}
      <div style="margin-bottom:4px">
        <strong>{{ planet.name }}</strong> {{ planet.distance }} AU
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="columns">
    <div class="column">
      <span class="label label--gray">{{ date }}</span>
    </div>
  </div>
</div>
