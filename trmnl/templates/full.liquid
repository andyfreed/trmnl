<!--
  TRMNL Solar System Viewer — Full Screen Layout
-->
<div class="layout layout--col">
  <div class="columns">
    <div class="column">
      <div class="markdown">
        <h1>Solar System</h1>
      </div>
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <table class="table">
        <thead>
          <tr>
            <th>Planet</th>
            <th style="text-align:right">Distance</th>
            <th style="text-align:right">Direction</th>
            <th style="text-align:right">Position</th>
          </tr>
        </thead>
        <tbody>
          {% for planet in planets %}
          <tr>
            <td><strong>{{ planet.name }}</strong></td>
            <td style="text-align:right">{{ planet.distance }} AU</td>
            <td style="text-align:right">{{ planet.direction }}</td>
            <td style="text-align:right">{{ planet.clock }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <span class="label label--gray">{{ date }} {{ time_utc }}</span>
    </div>
  </div>
</div>
