<!--
  TRMNL Solar System Viewer — Half Horizontal Layout
  Compact solar system diagram with planet distances.
-->
<div class="layout layout--col gap--space-between">
  <div class="columns">
    <div class="column">
      <div class="markdown">
        <h2>Solar System</h2>
      </div>
    </div>
  </div>

  <div class="columns">
    <div class="column" style="flex:2">
      <img src="data:image/svg+xml;base64,{{ img_half }}" width="350" height="210" />
    </div>
    <div class="column" style="flex:1">
      {% for planet in planets %}
      <div style="margin-bottom:2px">
        <span style="font-size:11px;font-weight:bold">{{ planet.abbrev }}</span>
        <span style="font-size:10px">{{ planet.distance_au }} AU</span>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <span class="label label--gray">{{ date }}</span>
    </div>
  </div>
</div>
