<!--
  TRMNL Solar System Viewer — Half Horizontal Layout
-->
<div class="layout layout--col gap--space-between">
  <div class="columns">
    <div class="column">
      <div class="markdown">
        <h2>Solar System</h2>
      </div>
    </div>
  </div>

  <div class="columns">
    <div class="column">
      {% for planet in planets %}
      {% if forloop.index <= 4 %}
      <div class="meta" {% unless forloop.last %}style="margin-bottom:8px"{% endunless %}>
        <span class="title title--small">{{ planet.name }}</span>
        <span class="description">
          {{ planet.distance }} AU &middot; {{ planet.direction }}
        </span>
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <span class="label label--gray">{{ date }}</span>
    </div>
  </div>
</div>
